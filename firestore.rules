rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Blog : lecture publique. Écriture uniquement via l'Admin SDK côté
    // serveur (routes /api/admin/*, qui contournent ces règles), jamais
    // depuis le client.
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // Portfolio : même politique que le blog.
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Soumissions du formulaire de contact : écrites uniquement côté serveur
    // (Firebase Admin SDK, qui ignore ces règles). Aucun accès depuis le client.
    match /contacts/{contactId} {
      allow read, write: if false;
    }

    // Tout le reste : fermé par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
