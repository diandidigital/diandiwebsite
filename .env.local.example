# Cloudinary — hébergement/optimisation des images
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Firebase Admin — écriture des soumissions du formulaire de contact dans Firestore
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Resend — notification email à chaque nouvelle soumission du formulaire de contact
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=

# Firebase (SDK client) — authentification admin et lecture/écriture des articles du blog
# Valeurs publiques (safe côté client), à récupérer dans Firebase Console > Project Settings > Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
